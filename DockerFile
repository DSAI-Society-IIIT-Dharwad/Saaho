FROM osrf/ros:humble-desktop

RUN apt update && apt install -y \
    ros-humble-turtlebot3-gazebo \
    ros-humble-turtlebot3* \
    python3-pip

# Install PyTorch with CUDA support (CUDA 11.8 compatible with RTX 2050)
# Use --trusted-host to bypass hash verification issues
RUN pip3 install --no-cache-dir --trusted-host download.pytorch.org \
    torch==2.5.1+cu118 torchvision==0.20.1+cu118 torchaudio==2.5.1+cu118 \
    --index-url https://download.pytorch.org/whl/cu118

ENV TURTLEBOT3_MODEL=burger

COPY scripts/container/ /opt/h2f/scripts/
RUN chmod +x /opt/h2f/scripts/*.sh